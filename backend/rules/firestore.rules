rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ---------- Helpers ----------
    function isSignedIn() { return request.auth != null; }
    function role() { return request.auth.token.role; }
    function isAdmin() { return isSignedIn() && role() == 'admin'; }
    function isVA() { return isSignedIn() && role() == 'va'; }
    function isClient() { return isSignedIn() && role() == 'client'; }
    function isOwner(uid) { return isSignedIn() && request.auth.uid == uid; }

    // ---------- Users ----------
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow update: if (isOwner(userId)
                       && !request.resource.data.diff(resource.data).affectedKeys()
                           .hasAny(['role', 'status', 'assignedClientIds', 'assignedVAIds']))
                    || isAdmin();
      allow create, delete: if isAdmin();
    }

    // ---------- Audit Logs (append-only, even for admins) ----------
    match /auditLogs/{logId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update, delete: if false;
    }

    // Default deny — explicit allows only for everything else (added as we build features)
    match /{document=**} {
      allow read, write: if false;
    }
  }
}